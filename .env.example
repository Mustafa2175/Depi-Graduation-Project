# ---------------------------------------------------------------------------
# Job Market Tracker — environment configuration
# Copy this file to `.env` and adjust. `.env` is git-ignored (never commit it).
# These same PG* variables are read by BOTH the Python loader
# (warehouse/config.py) and dbt (dbt/job_market_tracker/profiles.yml).
# ---------------------------------------------------------------------------

# PostgreSQL connection.
#   - Local install:        PGHOST=localhost
#   - Docker Compose:       PGHOST=db   (the compose service name)
PGHOST=localhost
PGPORT=5432
PGUSER=jobmarket
PGPASSWORD=jobmarket
PGDATABASE=job_market_tracker

# Where the cleaned (Silver) CSVs live, relative to the project root.
SILVER_DIR=data/silver

# ── Producers (optional; sensible defaults shown) ──────────────────────────
# JOB_QUERY=            # "" = broad; e.g. "data engineer" to focus the search
# MAX_JOBS=300          # cap per source per run
# MAX_PAGES=20          # page cap (paginated / browser sources)
# INCREMENTAL=1         # 1 = emit only postings not seen before; 0 = full re-scrape
# Browser-based producers (Bayt / Jobzella / Indeed):
# HEADFUL=1             # 1 = visible browser (Bayt needs it for Cloudflare); 0 = headless
# CHROME_BIN=           # path to chromium/chrome if not on PATH
# CHROMEDRIVER=         # path to chromedriver if not on PATH
# SCRAPER_PROXY=        # http://… proxy for blocked IPs (e.g. Indeed on cloud)

# NOTE: dbt's profile lives in dbt/job_market_tracker/profiles.yml and is
# located automatically by the Makefile / bootstrap.sh (they set an absolute
# DBT_PROFILES_DIR). Don't set a relative DBT_PROFILES_DIR here — it breaks
# once dbt runs from inside the project directory.
